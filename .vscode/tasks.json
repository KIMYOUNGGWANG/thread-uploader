{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Bridge to Codex",
      "type": "shell",
      "command": "./.agent/scripts/bridge.sh ${input:workflowName}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Generates optimized context for Codex using the selected workflow."
    },
    {
      "label": "🍃 Bridge to Codex (Lite)",
      "type": "shell",
      "command": "./.agent/scripts/bridge.sh ${input:workflowName} --lite",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Lightweight context (skips full skill content) for small tasks."
    },
    {
      "label": "🩺 Orchestrator Doctor",
      "type": "shell",
      "command": "bash ./.agent/scripts/doctor.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Validates the current project against the baseline orchestrator contract."
    }
  ],
  "inputs": [
    {
      "id": "workflowName",
      "type": "pickString",
      "description": "Select Workflow:",
      "options": [
        "brainstorm",
        "office-hours",
        "plan",
        "develop",
        "qa",
        "review",
        "ship",
        "fix",
        "status",
        "pm",
        "uiux",
        "test",
        "qa-only",
        "freeze",
        "unfreeze",
        "guard",
        "plan-ceo-review",
        "plan-eng-review",
        "plan-design-review"
      ],
      "default": "plan"
    }
  ]
}

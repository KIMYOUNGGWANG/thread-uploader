generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  brands    Brand[]
}

model Brand {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  accessToken    String
  threadsUserId  String
  tokenExpiry    DateTime
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  formulaWeights String   @default("{}")
  brandConfig    String   @default("{}")
  growthMemory   String   @default("{}")
  viralMemory    String   @default("{}")
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id])
  posts          Post[]
  viralExamples  ViralExample[]
  viralPatterns  ViralPattern[]
  accountInsights AccountInsight[]
  discoveredAccounts DiscoveredAccount[]
  accountPatterns AccountPattern[]
}

model Post {
  id           String    @id @default(cuid())
  brandId      String
  brand        Brand     @relation(fields: [brandId], references: [id])
  content      String
  imageUrls    String    @default("[]")
  scheduledAt  DateTime
  status       String    @default("PENDING")
  threadsId    String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  errorLog     String?
  firstComment String?
  formulaId    String?
  topic        String?
  targetAudience String?
  situation    String?
  hookType     String?
  ctaType      String?
  qualityScore Int?
  qualityProfile String?
  qualityPass Boolean?
  qualityReasons String @default("[]")
  campaignId String?
  campaignFormulaId String?
  careerDecisionType String?
  linkUrl String?
  utmContent String?
  clicks Int?
  conversions Int?
  manualPaidConversions Int?
  views        Int?
  likes        Int?
  replies      Int?
  reposts      Int?
  metricsAt    DateTime?
  performanceScore Int?
  performanceTier  String?
  learnedAt    DateTime?

  @@index([brandId, campaignId])
  @@index([brandId, scheduledAt])
  @@index([brandId, publishedAt])
}

model Settings {
  id             String   @id @default("default")
  accessToken    String
  userId         String
  tokenExpiry    DateTime
  updatedAt      DateTime @updatedAt
  formulaWeights String   @default("{}")
}

model ViralExample {
  id              String    @id @default(cuid())
  brandId         String
  brand           Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  source          String
  sourceKey       String
  authorUsername  String?
  permalink       String?
  content         String
  publishedAt     DateTime?
  discoveredAt    DateTime  @default(now())
  views           Int?
  likes           Int?
  replies         Int?
  reposts         Int?
  quotes          Int?
  shares          Int?
  engagementRate  Float?
  velocityScore   Int?
  viralScore      Int       @default(0)
  hookType        String?
  topic           String?
  targetAudience  String?
  emotionalDriver String?
  structureType   String?
  ctaType         String?
  patternSummary  String?
  keyTakeaway     String?
  rawMetrics      String    @default("{}")

  @@unique([brandId, source, sourceKey])
  @@index([brandId, viralScore])
  @@index([brandId, discoveredAt])
}

model ViralPattern {
  id              String   @id @default(cuid())
  brandId         String
  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  dimension       String
  value           String
  sourceCount     Int
  avgViralScore   Int
  confidence      Int
  exampleIds      String   @default("[]")
  recommendation  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([brandId, dimension, value])
  @@index([brandId, avgViralScore])
}

model AccountInsight {
  id          String   @id @default(cuid())
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  generatedAt DateTime @default(now())
  windowStart DateTime
  windowEnd   DateTime
  source      String   @default("cron")
  summary     String
  actions     String   @default("[]")
  metrics     String   @default("{}")
  createdAt   DateTime @default(now())

  @@index([brandId, generatedAt])
}

model DiscoveredAccount {
  id               String   @id @default(cuid())
  brandId          String
  brand            Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  username         String
  displayName      String?
  bio              String?
  profileUrl       String?
  status           String   @default("candidate")
  category         String   @default("unknown")
  relevanceScore   Int      @default(0)
  reason           String   @default("")
  source           String   @default("keyword_search")
  sourceKeyword    String?
  lastDiscoveredAt DateTime @default(now())
  lastScannedAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  posts            DiscoveredAccountPost[]
  patterns         AccountPattern[]

  @@unique([brandId, username])
  @@index([brandId, status])
  @@index([brandId, relevanceScore])
}

model DiscoveredAccountPost {
  id              String   @id @default(cuid())
  accountId       String
  account         DiscoveredAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceKey       String
  permalink       String?
  content         String
  publishedAt     DateTime?
  hookType        String?
  topic           String?
  emotionalDriver String?
  structureType   String?
  ctaType         String?
  patternSummary  String?
  relevanceScore  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([accountId, sourceKey])
  @@index([accountId, createdAt])
  @@index([relevanceScore])
}

model AccountPattern {
  id             String   @id @default(cuid())
  brandId        String
  brand          Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  accountId      String?
  account        DiscoveredAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dimension      String
  value          String
  sourceCount    Int
  confidence     Int
  recommendation String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([brandId, confidence])
  @@index([brandId, dimension])
  @@index([accountId])
}
